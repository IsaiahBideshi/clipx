{
  "name": "clipx",
  "version": "1.0.10",
  "description": "",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others --success first -n vite,electron \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "build:react": "vite build",
    "build:electron": "electron-builder build --win --publish never",
    "build": "vite build && electron-builder build --win --publish never",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.isaiah.clipx",
    "productName": "ClipX",
    "publish": [
      {
        "provider": "github",
        "owner": "IsaiahBideshi",
        "repo": "clipx"
      }
    ],
    "artifactName": "${productName}-Setup.${ext}",
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "files": [
      "electron/**/*",
      "dist/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/clipx_icon.ico"
    }
  },
  "private": true,
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.8",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-virtual": "^3.14.4",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "ffmpeg": "^0.0.4",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "fuse.js": "^7.1.0",
    "googleapis": "^171.4.0",
    "keytar": "7.9.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.0",
    "react-player": "^3.4.0",
    "react-router-dom": "^7.13.0"
  }
}
